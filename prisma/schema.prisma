generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  username           String              @unique
  passwordHash       String?
  name               String              @default("")
  emailVerified      DateTime?
  profile            Profile?
  oauthAccounts      OAuthAccount[]
  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  // Stamped (throttled, ~hourly) on any authenticated request — powers the
  // admin active-user counts. Null until the user's first visit after rollout.
  lastActiveAt       DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model VerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model Profile {
  id               String     @id @default(cuid())
  userId           String?    @unique
  user             User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String     @default("")
  email            String     @default("")
  statePrefs       String     @default("[]")
  targetTerm       String     @default("")
  overallGPA       Float?
  scienceGPA       Float?
  totalCredits     Int?
  coursesCompleted String     @default("[]")
  teasScore        Float?
  hesiScore        Float?
  casperQuartile   Int?
  casperPercentile Int?
  otherExamName    String?
  otherExamScore   Float?
  tier             String     @default("free")
  // When set, premium (tier 'cycle') is time-boxed and lapses to free after this
  // date. Used by 1-month admin access codes. null = no expiry (subscriptions).
  premiumUntil     DateTime?
  favorites        Favorite[]
  lists            List[]
  deadlines        Deadline[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Program {
  id              String     @id @default(cuid())
  slug            String?    @unique
  // Pretty, SEO-friendly URL key derived from the university name (e.g.
  // "arkansas-state-university"). Stable upsert key stays `slug`; this is only
  // for routing. Computed/deduped at seed time — see prisma/seed.ts.
  urlSlug         String?    @unique
  // The school's official admissions / program requirements page (real, working
  // link). Filled by the per-state research agents from official .edu sources.
  officialUrl     String?
  name            String
  university      String
  city            String
  state           String
  region          String     @default("")
  tier            String     @default("Local")
  isFlagship      Boolean    @default(false)
  isPublic        Boolean    @default(true)
  programType     String     @default("Traditional BSN")
  minOverallGPA   Float?
  minScienceGPA   Float?
  requiredCourses String     @default("[]")
  examType        String?
  minExamScore    Float?
  casperRequired  Boolean    @default(false)
  deadlines       String?
  notes           String?
  dataQuality     String     @default("placeholder") // placeholder | partial | verified
  // JSON array of requirement field names whose values are AI estimates rather
  // than published data (e.g. ["minOverallGPA","examType"]). Cleared on verify.
  estimatedFields String     @default("[]")
  favorites       Favorite[]
  listItems       ListItem[]
  deadlineEntries Deadline[]
  outcomes        Outcome[]
}

// Crowdsourced, self-reported admission outcomes for a program ("I got in with a
// 3.6 / 78 TEAS"). Public submissions, no account required. Powers aggregate
// "real admitted-student stats" on each program page — unique data + SEO moat.
model Outcome {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  result     String   // 'admitted' | 'waitlisted' | 'rejected'
  overallGPA Float?
  scienceGPA Float?
  examType   String? // 'TEAS' | 'HESI A2' | 'NLN PAX'
  examScore  Float?
  cycleYear  Int?
  createdAt  DateTime @default(now())

  @@index([programId])
}

model Favorite {
  id        String   @id @default(cuid())
  profileId String
  programId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([profileId, programId])
}

// A named collection of programs owned by a profile. Every profile has one
// isDefault list ("Saved") that replaces the old flat favorites; premium users
// can create additional named lists ("Dream Schools", "Safe Schools").
model List {
  id        String     @id @default(cuid())
  profileId String
  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean    @default(false)
  items     ListItem[]
  createdAt DateTime   @default(now())

  @@index([profileId])
}

model ListItem {
  id        String   @id @default(cuid())
  listId    String
  programId String
  list      List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([listId, programId])
}

// A premium user's application deadline for a program. remindersSent is a JSON
// array of milestone day-counts already emailed (e.g. [30,14]) so the reminder
// runner never double-sends.
model Deadline {
  id            String   @id @default(cuid())
  profileId     String
  programId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  program       Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  deadlineDate  DateTime
  label         String   @default("")
  remindersSent String   @default("[]")
  createdAt     DateTime @default(now())

  @@unique([profileId, programId])
}

model AccessCode {
  id          String                 @id @default(cuid())
  code        String                 @unique
  type        String                 @default("month") // 'month' | 'lifetime'
  maxUses     Int                    @default(1)
  usedCount   Int                    @default(0)
  usedBy      String? // legacy single-use field, superseded by redemptions
  usedAt      DateTime?
  createdAt   DateTime               @default(now())
  redemptions AccessCodeRedemption[]
}

model AccessCodeRedemption {
  id         String     @id @default(cuid())
  codeId     String
  profileId  String
  redeemedAt DateTime   @default(now())
  code       AccessCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@unique([codeId, profileId])
}

// Email captured via a free lead-magnet download (e.g. the prerequisite checklist).
// Not tied to a user account — top-of-funnel marketing list.
model Lead {
  id        String   @id @default(cuid())
  email     String
  magnet    String   @default("bsn-prerequisite-checklist")
  source    String?
  createdAt DateTime @default(now())

  @@unique([email, magnet])
}

model SchoolRequest {
  id          String    @id @default(cuid())
  schoolName  String
  university  String
  city        String
  state       String
  programType String    @default("BSN")
  reason      String?
  requestedBy String?
  status      String    @default("new") // new | in_progress | added | wont_add
  resolution  String? // notes from the agent (e.g. added slug, why rejected)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
}
